# Secrets only — all other settings are in config.json
# These can also be set via the Settings tab in the app.

# OpenAI API key (for NL parsing and vision analysis)
OPENAI_API_KEY=sk-your-key-here

# HuggingFace token (required for SAM3 gated model access)
HF_TOKEN=hf_your-token-here

# Optional: skip HuggingFace network checks after first run
# HF_HUB_OFFLINE=1
