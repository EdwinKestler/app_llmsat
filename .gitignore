# This is a new file app_stremlit/.gitignore

# Environment variables and sensitive files
.env

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Streamlit secrets
.secrets/
secrets.toml

# Output directories from pipeline
output/
data/

# Streamlit cache
.streamlit/

# Model checkpoints
checkpoints/*
!checkpoints/.gitkeep  # Keep empty checkpoints directory if needed

# Temporary files
*.log
*.tmp
*.bak
*.swp

# IDE and editor files
.vscode/
.idea/
*.sublime-*

# OS-specific files
.DS_Store
Thumbs.db