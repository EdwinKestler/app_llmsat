# ── Secrets & user config ────────────────────────────────────────
.env
config.json

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/

# ── Pipeline output (regenerated at runtime) ─────────────────────
output/
data/

# ── Model checkpoints (large, download separately) ───────────────
checkpoints/*
!checkpoints/.gitkeep

# ── Cached imagery tiles ─────────────────────────────────────────
EsriCache/
*.tif

# ── Open Buildings data (large, download separately) ─────────────
openbuildings/*.csv.gz
openbuildings/*.csv

# ── Legacy / archived files ──────────────────────────────────────
old_files/

# ── IDE & editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-*

# ── OS artifacts ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*Zone.Identifier

# ── Misc artifacts ───────────────────────────────────────────────
=*
*.log
*.tmp
*.bak
*.swp

# ── Streamlit ────────────────────────────────────────────────────
.streamlit/secrets.toml
